# Production/Replit persistence checklist.
# Copy values into Replit Secrets, not into a committed .env file.

NODE_ENV=production
PORT=8080

# Real persistence. Required outside dev mock mode.
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DATABASE

# Dev-only bypasses must stay false in production.
DEV_MOCK_API=false
DEV_AUTH_BYPASS=false
VITE_DEV_AUTH_BYPASS=false

# Clerk web/API auth.
CLERK_PUBLISHABLE_KEY=pk_live_or_test_...
CLERK_SECRET_KEY=sk_live_or_test_...
VITE_CLERK_PUBLISHABLE_KEY=pk_live_or_test_...
VITE_CLERK_PROXY_URL=/api/__clerk

# Optional AI counsel. The app has fallbacks when these are absent.
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Expo/mobile builds should point at the deployed web/API origin.
EXPO_PUBLIC_API_BASE_URL=https://your-domain.example
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_or_test_...
