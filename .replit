modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 20167
externalPort = 80

[userenv]

[userenv.shared]
VAPID_PUBLIC_KEY = "uft1w6VLQ1l2cDZEevSC-qiOHJ3W88nxGFWI4RYFJfR87XyYeRtg14qA0fQn99ZGupKPVp3slUCgym7C6mDHhQ"
VAPID_PRIVATE_KEY = "aZ1lHEUTBdqg8Cc6iF1Cct8NC5j1TGUBk8xA2mFJvV8"
